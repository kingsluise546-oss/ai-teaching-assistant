      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/assistant/prepare-lesson)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/assistant/generate-questions)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/assistant/write-comment)",
      "Bash(taskkill *)",
      "Bash(curl -s http://localhost:3001/workspace)",
      "Bash(git *)"
    ]
  }
}
