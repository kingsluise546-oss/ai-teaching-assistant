{
  "permissions": {
    "allow": [
      "Bash(npx next *)",
      "Bash(lsof -ti:3000)",
      "Bash(xargs kill -9)",
      "Bash(netstat -ano)",
      "Bash(findstr :3000)",
      "Bash(taskkill //PID 15068 //F)",
